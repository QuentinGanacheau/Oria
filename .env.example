# API (Nest) — default port 4000
PORT=4000
FRONTEND_URL=http://localhost:3000
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/findyourjob?schema=public

# IA (optionnel). Sans clé, l'app utilise un fallback déterministe.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

# Stripe (optionnel — sans clé, le paiement reste désactivé côté API)
STRIPE_SECRET_KEY=
STRIPE_PRICE_FULL_REPORT=
STRIPE_WEBHOOK_SECRET=

# Web (Next)
NEXT_PUBLIC_API_URL=http://localhost:4000
