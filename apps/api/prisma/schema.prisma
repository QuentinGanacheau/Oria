generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum SessionStatus {
  ACTIVE
  COMPLETED
  ABANDONED
}

model Question {
  id             String           @id @default(cuid())
  key            String           @unique
  text           String
  // "SINGLE_CHOICE" | "FREE_TEXT" (SQLite n'a pas d'enum, on stocke en string)
  type           String           @default("SINGLE_CHOICE")
  placeholder    String?
  helperText     String?
  orderHint      Int              @default(0)
  active         Boolean          @default(true)
  askIfEquals    Json?
  askIfNotEquals Json?
  /// Affiche la question si la réponse à la clé EST dans le tableau.
  /// Ex : { "situation": ["actif", "reconversion"] }
  askIfIn        Json?
  /// Affiche la question si la réponse à la clé N'EST PAS dans le tableau.
  /// Ex : { "situation": ["lycee", "etudes_longues"] }
  askIfNotIn     Json?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  options        QuestionOption[]
  answers        SessionAnswer[]
}

model QuestionOption {
  id         String   @id @default(cuid())
  key        String
  label      String
  /// Poids des anciens slugs métier (legacy — sera supprimé après migration complète vers ROME).
  jobWeights Json
  /// Poids des grands domaines ROME (Phase 2). Format : { "M": 3, "J": 2, ... }
  /// où la clé est le code ROME du grand domaine. Optionnel le temps de la migration.
  domainWeights Json?
  questionId String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
  answers    SessionAnswer[]

  @@unique([questionId, key])
}

model QuestionnaireSession {
  id        String          @id @default(cuid())
  status    SessionStatus   @default(ACTIVE)
  metadata  Json?
  /// Email de l'utilisateur, capturé avant l'affichage des résultats.
  /// Null si l'utilisateur a skipé la capture → pas de restauration possible.
  email        String?
  /// Consentement RGPD explicite à recevoir les emails.
  emailConsent Boolean      @default(false)
  /// Paiement confirmé via Stripe — permet de restaurer le statut "débloqué"
  /// quand l'utilisateur revient via le lien email sans localStorage.
  isPaid       Boolean      @default(false)
  /// Date d'expiration de la session (accès aux résultats via lien email).
  /// null = pas d'expiration (théorique)
  /// Valeurs définies à la complétion :
  ///   - Gratuit  → now + 30 jours
  ///   - Payant   → now + 1 an (prolongé à la confirmation de paiement)
  expiresAt    DateTime?
  /// Portrait IA généré à la fin du questionnaire (Phase 2).
  /// Contient l'archétype, les 3 forces, ce qui anime et ce qui épuise.
  /// Format : PortraitContent (cf. ai.service.ts).
  /// Null si l'IA était indisponible — le frontend skippe l'écran portrait.
  portrait     Json?
  /// Résultats de la 2e passe (affinés par les notes utilisateur, Phase 4).
  /// Null tant que l'utilisateur n'a pas payé et déclenché le raffinement.
  /// Format : Array<RefinedMatch> — même structure que les matches de la passe 1.
  refinedMatches Json?
  /// Insight IA généré avec la 2e passe : phrase expliquant ce que les notes
  /// révèlent sur le profil (ex: "Tu apprécies les métiers créatifs et techniques").
  refineInsight  String?
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
  answers   SessionAnswer[]
  matches   MatchResult[]
  ratings   JobRating[]
  refinedBatches RefinedBatch[]
  batchProbes    BatchProbe[]

  @@index([email])
}

/// Un "batch" de résultats affinés généré par l'IA à partir des notes
/// accumulées (swipe deck — batches progressifs).
///
/// La passe 1 gratuite vit dans `MatchResult` (rank 1-10). Les batches affinés
/// commencent donc à `batchNumber = 2`. Chaque appel à `generateNextBatch`
/// crée une ligne ici : c'est le cache (un batch n'est jamais recalculé) ET
/// l'historique permettant d'exclure les métiers déjà servis du batch suivant.
model RefinedBatch {
  id          String   @id @default(cuid())
  sessionId   String
  /// Index global du batch. 1 = passe gratuite (dans MatchResult), 2+ = ici.
  batchNumber Int
  /// Array<MatchOutput> hydraté (job complet + score + rationale), figé au moment
  /// de la génération — même structure que ce que le frontend stocke en local.
  matches     Json
  /// Phrase IA d'introduction du batch ("Tu apprécies les métiers qui…").
  insight     String?
  /// Nombre total de notes de la session au moment de générer ce batch.
  /// Sert de garde-fou anti-spam : on exige N nouvelles notes avant le batch suivant.
  ratingsAtCreation Int @default(0)
  createdAt   DateTime @default(now())
  session     QuestionnaireSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@unique([sessionId, batchNumber])
  @@index([sessionId])
}

/// Question A/B d'affinage posée entre deux batches du swipe deck.
///
/// Avant de générer le batch N+1, l'IA repère une tension dans les swipes et
/// propose deux axes opposés (`axisA` / `axisB`). Le label choisi est injecté
/// dans `formattedAnswers` pour re-prioriser le batch — signal de préférence
/// explicite qui complète le signal implicite des likes/dislikes.
///
/// `batchNumber` = le batch que la question précède (≥ 2). `@@unique` rend la
/// génération idempotente : un refresh re-récupère la même question.
/// `answer` null = question générée mais pas encore répondue (ou skipée).
model BatchProbe {
  id          String   @id @default(cuid())
  sessionId   String
  /// Batch que cette question précède (2+). Idempotence par couple session/batch.
  batchNumber Int
  /// Phrase d'introduction / la question elle-même ("Ce qui t'attire surtout ?").
  intro       String
  /// Premier axe proposé (ex: "le contact humain").
  axisA       String
  /// Second axe proposé (ex: "l'impact concret").
  axisB       String
  /// Label de l'axe choisi par l'utilisateur. Null tant que pas répondu / skipé.
  answer      String?
  createdAt   DateTime @default(now())
  session     QuestionnaireSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@unique([sessionId, batchNumber])
  @@index([sessionId])
}

/// Note posée par l'utilisateur sur un métier après avoir vu ses résultats.
/// Signal clé pour la 2e passe de matching (Phase 4).
model JobRating {
  id        String   @id @default(cuid())
  sessionId String
  /// Code ROME du métier noté (ex: "M1805").
  jobSlug   String
  /// "like" | "dislike" | "neutral"
  rating    String
  /// Raison optionnelle du dislike — chips pré-définies et/ou texte libre.
  /// Null pour les "like" et "neutral", optionnel pour les "dislike".
  /// Signal très utile pour affiner la 2e passe IA.
  reason    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  session   QuestionnaireSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@unique([sessionId, jobSlug])  // une note par couple — idempotent
  @@index([sessionId])
}

model SessionAnswer {
  id                String               @id @default(cuid())
  sessionId         String
  questionId        String
  // Réponse de type QCM : référence l'option choisie
  optionId          String?
  // Réponse de type texte libre
  freeText          String?
  // Poids métiers extraits par l'IA à partir du texte libre (cache pour éviter de rappeler l'IA)
  extractedWeights  Json?
  // Phase 6 — question de relance générée par l'IA + réponse de l'utilisateur
  followUpQuestion  String?
  followUpAnswer    String?
  createdAt         DateTime             @default(now())
  session           QuestionnaireSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  question          Question             @relation(fields: [questionId], references: [id], onDelete: Restrict)
  option            QuestionOption?      @relation(fields: [optionId], references: [id], onDelete: Restrict)

  @@unique([sessionId, questionId])
  @@index([sessionId])
}

model MatchResult {
  id                 String               @id @default(cuid())
  sessionId          String
  jobSlug            String
  score              Float
  rank               Int
  rationale          String?
  // Fiche personnalisée générée à la demande (lazy) — null tant que l'utilisateur
  // n'a pas visité la page fiche. Cache permanent : généré une fois, servi à l'infini.
  personalizedContent Json?
  createdAt          DateTime             @default(now())
  session            QuestionnaireSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@index([sessionId, jobSlug]) // Lookup direct par session + métier
}

/// Métier importé depuis l'API ROME 4.0 de France Travail.
/// Sert de source de données pour le matching (Phase 2). Mis à jour via
/// le script `npm run sync:rome` qui appelle l'API et upsert toutes les fiches.
model RomeJob {
  id                     String   @id @default(cuid())
  /// Code ROME unique (ex: "M1805") — identifiant officiel France Travail.
  code                   String   @unique
  libelle                String
  definition             String?
  /// Hiérarchie ROME — utilisée en Phase 2 pour le filtrage par grand domaine.
  codeGrandDomaine       String?
  libelleGrandDomaine    String?
  codeDomaine            String?
  libelleDomaine         String?
  /// Compétences "savoirs" et "savoir-faire" stockées en JSON pour souplesse.
  /// Format attendu : Array<{ libelle: string; code?: string; type?: string }>.
  competencesSavoirs     Json?
  competencesSavoirFaire Json?
  /// Contextes de travail (lieux, conditions…) — JSON brut depuis l'API.
  contextesTravail       Json?
  /// Conditions d'accès au métier (niveau de diplôme, formations).
  /// Texte libre extrait du champ `accesEmploi` de l'API ROME.
  accesEmploi            String?
  /// Nombre d'offres d'emploi actives pour ce code ROME, relevé pendant la sync
  /// via l'API « Offres d'emploi v2 » (en-tête Content-Range). Null si l'appel
  /// a échoué ou si l'API Offres n'est pas configurée.
  offerCount             Int?
  /// Niveau de recrutement dérivé de `offerCount`, normalisé par percentile sur
  /// l'ensemble des métiers : "high" | "medium" | "low". Null tant que la passe
  /// de finalisation n'a pas tourné (ou si aucune donnée d'offres).
  /// Corrige le biais de taille de domaine : c'est un niveau *relatif* aux autres métiers.
  recruitmentLevel       String?
  /// Date du dernier import — permet de détecter les fiches obsolètes.
  syncedAt               DateTime @default(now())
  createdAt              DateTime @default(now())

  @@index([codeGrandDomaine])
  @@index([codeDomaine])
}

model FeedbackEvent {
  id          String   @id @default(cuid())
  sessionId   String?
  eventType   String
  rating      Int?
  selectedJob String?
  payload     Json?
  createdAt   DateTime @default(now())

  @@index([sessionId])
  @@index([eventType])
}

/// Trace de tous les emails envoyés depuis l'app.
/// Permet d'auditer la délivrabilité, de retrouver un envoi spécifique en cas
/// de support utilisateur, et d'éviter les doubles envois.
model EmailLog {
  id         String   @id @default(cuid())
  sessionId  String?
  /// Adresse destinataire (en clair — déjà fournie par l'utilisateur).
  to         String
  /// Type d'email pour faciliter le filtrage et le débogage.
  /// Valeurs : "results" | "payment_confirmation" | "unlock_reminder"
  type       String
  /// "sent" | "failed"
  status     String
  /// ID retourné par Resend, utile pour retrouver le mail dans leur dashboard.
  providerId String?
  /// Message d'erreur si status = "failed" (raison de l'échec).
  error      String?
  sentAt     DateTime @default(now())

  @@index([sessionId])
  @@index([to])
  @@index([type])
}
